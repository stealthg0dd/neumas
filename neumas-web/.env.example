# Copy to .env.local and fill in values
# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# Direct URL used by the Axios API client in the browser (Railway).
# Leave empty or set to /api to proxy through Next.js rewrites instead.
NEXT_PUBLIC_API_URL=https://neumas-production.up.railway.app

# ---------------------------------------------------------------------------
# Supabase — public (safe to expose to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Supabase — server-only (NEVER expose to the browser — no NEXT_PUBLIC_ prefix)
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Agent OS (router-system registration)
# ---------------------------------------------------------------------------
AGENT_OS_URL=https://your-agent-os.up.railway.app
AGENT_OS_API_KEY=your-agent-os-api-key

# ---------------------------------------------------------------------------
# Environment ("development" | "staging" | "production")
# ---------------------------------------------------------------------------
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Sentry (optional — error tracking)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=   # CI/CD only — for source-map uploads
# SENTRY_ORG=

# ---------------------------------------------------------------------------
# PostHog (optional — product analytics)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
